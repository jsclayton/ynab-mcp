{
  "name": "@jsclayton/ynab-mcp",
  "version": "0.1.1",
  "exports": {
    ".": "./src/stdio.ts",
    "./http": "./src/http.ts"
  },
  "publish": {
    "include": ["src/", "deno.json", "LICENSE.txt", "README.md"],
    "exclude": ["src/testing/", "**/*_test.ts"]
  },
  "imports": {
    "@modelcontextprotocol/sdk/server/mcp.js": "npm:@modelcontextprotocol/sdk@1.27.1/server/mcp.js",
    "@modelcontextprotocol/sdk/server/stdio.js": "npm:@modelcontextprotocol/sdk@1.27.1/server/stdio.js",
    "@modelcontextprotocol/sdk/server/streamableHttp.js": "npm:@modelcontextprotocol/sdk@1.27.1/server/streamableHttp.js",
    "@modelcontextprotocol/sdk/server/webStandardStreamableHttp.js": "npm:@modelcontextprotocol/sdk@1.27.1/server/webStandardStreamableHttp.js",
    "@hono/mcp": "jsr:@hono/mcp@0.2.0",
    "hono": "jsr:@hono/hono@4.12.8",
    "hono/": "jsr:@hono/hono@4.12.8/",
    "zod": "npm:zod@3.25.76",
    "@std/testing/assert": "jsr:@std/assert@1.0.19",
    "@std/testing/bdd": "jsr:@std/testing@1.0.17/bdd",
    "@std/testing/mock": "jsr:@std/testing@1.0.17/mock",
    "@std/testing/snapshot": "jsr:@std/testing@1.0.17/snapshot",
    "@std/testing/time": "jsr:@std/testing@1.0.17/time",
    "@std/testing/types": "jsr:@std/testing@1.0.17/types"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-read src/stdio.ts",
    "serve": "deno run --allow-net --allow-env --allow-read src/http.ts",
    "dev": "deno run --watch --allow-net --allow-env --allow-read src/stdio.ts",
    "test": "deno test --allow-env --allow-read src/",
    "test:watch": "deno test --watch --allow-env --allow-read src/",
    "check": "deno check src/stdio.ts src/http.ts",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "fmt": {
    "exclude": ["*.md", "docs/"]
  },
  "compilerOptions": {
    "strict": true
  }
}
